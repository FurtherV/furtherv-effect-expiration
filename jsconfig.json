{
  "compilerOptions": {
    "module": "ES6",
    "target": "ES6",
    "paths": {
      "@client/*": [
        "./foundry/client/*"
      ],
      "@common/*": [
        "./foundry/common/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules/*",
    "dest"
  ],
  "include": [
    "src/module.mjs",
    "src/debug.mjs",
    "foundry/client/",
    "foundry/client-esm/",
    "foundry/common/"
  ],
  "typeAcquisition": {
    "include": [
      "jquery"
    ]
  }
}